{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "isolatedModules": false,
    "noImplicitOverride": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "imports": {
    "@bitcoin/bitcoin-ts": "./src/index.ts"
  },
  "tasks": {
    "test": "deno test --allow-all src/",
    "check": "deno check --unstable-sloppy-imports src/",
    "fmt": "deno fmt src/",
    "lint": "deno lint src/"
  },
  "exclude": ["node_modules", "dist"]
}
