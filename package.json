{
  "name": "bitcoin-ts",
  "version": "0.1.0",
  "description": "TypeScript port of Bitcoin Core foundational types",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node dist/test.js",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "bitcoin",
    "cryptocurrency",
    "typescript"
  ],
  "author": "Bitcoin Core developers",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3"
  }
}
